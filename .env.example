# cam2ip MCP Server Configuration
# Copy this file to .env and customize as needed

# Enable/disable the built-in cam2ip server
# Set to "false" when using an external cam2ip instance
CAM2IP_ENABLED=true

# Camera settings
CAM2IP_INDEX=0
CAM2IP_WIDTH=640
CAM2IP_HEIGHT=480
CAM2IP_QUALITY=75
CAM2IP_DELAY=10

# Network settings
CAM2IP_BIND_ADDR=0.0.0.0:56000
CAM2IP_BASE_URL=http://127.0.0.1:56000

# MCP server settings
CAM2IP_HTTP_TIMEOUT_S=5.0

# MCP transport mode:
#   stdio           - MCP over stdin/stdout (default, for Claude Desktop, Cline, etc.)
#   sse             - MCP over Server-Sent Events (legacy HTTP transport)
#   streamable-http - MCP over Streamable HTTP (current spec transport)
MCP_MODE=stdio
MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_PORT=3000

# Optional: Image processing
# CAM2IP_ROTATE=0
# CAM2IP_FLIP=
# CAM2IP_TIMESTAMP=false
# CAM2IP_TIME_FORMAT=2006-01-02 15:04:05

# Optional: Authentication
# CAM2IP_HTPASSWD_FILE=/path/to/htpasswd
